{
  "monitorId": "optional-monitor-id-for-monitoring-fallback",
  "promptId": "optional-prompt-id-for-analytics-ingest",
  "runLabel": "chatgpt-internal-visibility-check",
  "client": "chatgpt",
  "platform": "web",
  "model": "chatgpt-web",
  "browser": {
    "channel": "msedge",
    "headless": false
  },
  "navigation": {
    "url": "https://chatgpt.com/",
    "waitUntil": "domcontentloaded",
    "timeoutMs": 30000
  },
  "prompt": {
    "text": "You are helping an internal monitoring team. In 4 concise bullets, explain reliable ways to monitor AI response visibility and citation quality for internal products. Include at least 3 source links.",
    "inputSelector": "#prompt-textarea, [contenteditable='true'], textarea",
    "submitSelector": "button[data-testid='send-button'], button[aria-label*='Send']",
    "submitKey": "Enter",
    "clearExisting": true
  },
  "extraction": {
    "responseContainerSelector": "[data-message-author-role='assistant']:not([data-message-id*='request-placeholder']):last-of-type",
    "responseTextSelector": "[data-message-author-role='assistant']:not([data-message-id*='request-placeholder']):last-of-type",
    "citationLinkSelector": "a[href]",
    "maxCitations": 20
  },
  "authProfile": {
    "authType": "file",
    "localRef": "runner/example.auth-profile.json"
  },
  "assertions": {
    "urlIncludes": "chatgpt.com"
  },
  "timing": {
    "responseTimeoutMs": 45000,
    "settleDelayMs": 1500
  },
  "ingest": {
    "target": "auto"
  }
}
