{
  "monitorId": "optional-monitor-id-for-monitoring-fallback",
  "promptId": "optional-prompt-id-for-analytics-ingest",
  "runLabel": "google-ai-mode-organic-smoke",
  "provider": "google",
  "platform": "web",
  "sessionMode": "guest",
  "browser": {
    "engine": "camoufox",
    "headless": false,
    "camoufox": {
      "humanize": 0.8,
      "geoip": false,
      "addons": ["runner/addons/buster"]
    }
  },
  "navigation": {
    "url": "https://www.google.com/",
    "navigationStrategy": "organic",
    "organic": {
      "searchInputSelector": "textarea[name='q'], input[name='q']",
      "aiTabSelector": "a[href*='udm=50']",
      "typeDelayMs": 110,
      "postTypeSettleMs": 600,
      "postClickSettleMs": 3000,
      "captchaTimeoutMs": 90000
    },
    "waitUntil": "domcontentloaded",
    "timeoutMs": 30000,
    "hopWaitUntil": "load",
    "domainHops": [
      { "url": "https://en.wikipedia.org/wiki/Main_Page", "waitAfterMs": 4000 },
      { "url": "https://news.ycombinator.com/", "waitAfterMs": 3500 },
      { "url": "https://github.com/", "waitAfterMs": 3500 }
    ]
  },
  "prompt": {
    "text": "what is the tallest mountain in europe",
    "clearExisting": false
  },
  "extraction": {
    "responseContainerSelector": "[data-xid='aim-mars-turn-root'] [data-subtree='aimc']",
    "responseTextSelector": "[data-xid='aim-mars-turn-root'] [data-subtree='aimc']",
    "citationLinkSelector": "[data-xid='aim-mars-turn-root'] a[href^='https://']:not([href*='google.com']):not([href*='gstatic.com'])",
    "maxCitations": 20
  },
  "assertions": {
    "urlIncludes": "udm=50"
  },
  "timing": {
    "responseStartTimeoutMs": 30000,
    "responseTimeoutMs": 120000,
    "responseStableMs": 4000,
    "settleDelayMs": 1500
  },
  "ingest": {
    "target": "none"
  }
}
