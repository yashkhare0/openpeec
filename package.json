{
  "name": "openpeec",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node runner/install-camoufox.mjs && node runner/install-buster.mjs",
    "dev": "npm-run-all --parallel dev:backend dev:frontend dev:runner",
    "kill": "node scripts/kill-dev.mjs",
    "dev:frontend": "vite --open",
    "dev:backend": "node scripts/dev-backend.mjs",
    "dev:runner": "node runner/process-queued-runs.mjs --config runner/example.monitor.json --poll-interval-ms 1000 --headed",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit && tsc -p convex/tsconfig.json --noEmit && tsc -p tsconfig.e2e.json --noEmit",
    "build": "pnpm typecheck && vite build",
    "lint": "eslint . --ext ts,tsx,mts,cjs --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "test": "vitest",
    "test:once": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:vite-only": "OPENPEEC_E2E_LIVE=0 playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:coverage": "vitest run --coverage --coverage.reporter=text",
    "check": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm test:once && pnpm test:e2e",
    "runner:monitor": "node runner/run-monitor.mjs",
    "runner:monitor:example": "node runner/run-monitor.mjs --config runner/example.monitor.json --output runner/last-run.json",
    "runner:prompt:example": "node runner/run-monitor.mjs --config runner/example.monitor.json --output runner/last-run.json",
    "runner:capture-session": "node runner/capture-session.mjs",
    "runner:open-session": "node runner/open-session-window.mjs",
    "runner:install-browsers": "playwright install chromium",
    "runner:install-camoufox": "node runner/install-camoufox.mjs",
    "runner:install-buster": "node runner/install-buster.mjs",
    "runner:install-nodriver": "node runner/install-nodriver.mjs",
    "runner:nodriver:fixture": "node runner/run-monitor.mjs --config runner/example.nodriver-fixture.json --output runner/last-run.nodriver.json && node runner/assert-nodriver-fixture-result.mjs runner/last-run.nodriver.json",
    "runner:nodriver:fixture:docker": "node runner/run-monitor.mjs --config runner/example.nodriver-fixture.docker.json --output runner/last-run.nodriver.json && node runner/assert-nodriver-fixture-result.mjs runner/last-run.nodriver.json",
    "runner:stealth-smoke": "node runner/stealth-smoke.mjs --engine camoufox",
    "runner:smoke:google": "node runner/run-monitor.mjs --config runner/example.google-ai-mode.json --output runner/last-run.google.json",
    "runner:smoke:mistral": "node runner/run-monitor.mjs --config runner/example.mistral-smoke.json --output runner/last-run.mistral.json",
    "runner:queue": "node runner/process-queued-runs.mjs --config runner/example.monitor.json --poll-interval-ms 1000 --headed",
    "runner:queue:once": "node runner/process-queued-runs.mjs --config runner/example.monitor.json --once --headed",
    "runner:queue:docker": "node runner/process-queued-runs.mjs --config runner/example.monitor.docker.json --poll-interval-ms 1000",
    "runner:queue:docker:once": "node runner/process-queued-runs.mjs --config runner/example.monitor.docker.json --once",
    "runner:queue:nodriver": "node runner/process-queued-runs.mjs --config runner/example.nodriver-chatgpt.json --poll-interval-ms 1000",
    "runner:queue:nodriver:once": "node runner/process-queued-runs.mjs --config runner/example.nodriver-chatgpt.json --once",
    "codex:bridge:setup": "tsx src/cli/codex-bridge-setup.ts",
    "codex:bridge:start": "tsx src/cli/codex-bridge-start.ts",
    "docker:dev": "docker compose up --build",
    "docker:nodriver:fixture": "docker compose run --build --rm runner-nodriver"
  },
  "dependencies": {
    "@convex-dev/crons": "^0.1.9",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "convex": "^1.25.0",
    "driver.js": "^1.4.0",
    "lucide-react": "^0.441.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "recharts": "2.15.4",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^4.0.3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.1",
    "convex-test": "^0.0.29",
    "eslint": "8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.12",
    "jsdom": "^29.0.0",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2",
    "vite": "^6.4.1",
    "vitest": "^2.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
