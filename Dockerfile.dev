FROM node:22-bookworm

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
ENV CAMOUFOX_PYTHON=/usr/bin/python3
ENV OPENPEEC_NODRIVER_BROWSER_PATH=/usr/bin/chromium
ENV OPENPEEC_NODRIVER_PYTHON=/usr/bin/python3

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    chromium \
    curl \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libatspi2.0-0 \
    libcairo2 \
    libcups2 \
    libdbus-glib-1-2 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libpango-1.0-0 \
    libx11-xcb1 \
    libxcb-shm0 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxkbcommon0 \
    libxrandr2 \
    libxss1 \
    libxt6 \
    python3 \
    python3-pip \
    python3-venv \
  && rm -rf /var/lib/apt/lists/*

COPY runner/requirements-nodriver.txt /tmp/requirements-nodriver.txt
COPY runner/requirements-camoufox.txt /tmp/requirements-camoufox.txt
RUN python3 -m pip install --break-system-packages \
    -r /tmp/requirements-nodriver.txt \
    -r /tmp/requirements-camoufox.txt \
  && python3 -m camoufox fetch
RUN corepack enable

WORKDIR /app

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
