{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend-preview",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "vite", "--port", "5998", "--host", "127.0.0.1", "--mode", "development"],
      "port": 5998,
      "autoPort": false,
      "env": {
        "VITE_CONVEX_URL": "http://127.0.0.1:3212"
      }
    },
    {
      "name": "frontend",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev:frontend"],
      "port": 5999,
      "autoPort": false
    },
    {
      "name": "backend",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev:backend"],
      "port": 3210
    },
    {
      "name": "runner",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev:runner"],
      "port": null
    }
  ]
}
